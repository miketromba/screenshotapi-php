{
	"name": "screenshotapi/sdk",
	"description": "Official PHP SDK for ScreenshotAPI",
	"type": "library",
	"license": "MIT",
	"keywords": [
		"screenshot",
		"api",
		"screenshotapi",
		"webpage",
		"capture",
		"browser",
		"image"
	],
	"homepage": "https://screenshotapi.to",
	"authors": [
		{
			"name": "ScreenshotAPI",
			"email": "support@screenshotapi.to",
			"homepage": "https://screenshotapi.to",
			"role": "Developer"
		}
	],
	"support": {
		"email": "support@screenshotapi.to",
		"docs": "https://screenshotapi.to/docs/sdks/php",
		"issues": "https://github.com/miketromba/screenshotapi-php/issues",
		"source": "https://github.com/miketromba/screenshotapi-php"
	},
	"require": {
		"ext-json": "*",
		"php": ">=8.1",
		"guzzlehttp/guzzle": "^7.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"ScreenshotAPI\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ScreenshotAPI\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit --configuration phpunit.xml.dist"
	}
}
